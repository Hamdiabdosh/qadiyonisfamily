# Local dev: copy to .env, then `docker compose up -d postgres` and `bun run dev`
POSTGRES_HOST=localhost
POSTGRES_PORT=5437
POSTGRES_USER=app
POSTGRES_PASSWORD=devpass
POSTGRES_DB=qadiyonis
SESSION_SECRET=local-dev-change-me-before-production
VITE_APP_URL=http://localhost:8080

# --- Production (Coolify / Docker Compose) ---
# Required:
#   POSTGRES_PASSWORD=<strong random>
#   SESSION_SECRET=<strong random, 32+ chars>
#   VITE_APP_URL=https://qadiyonis.raafat.site
#
# Optional:
#   LLM_API_KEY=<your key>
#   VAPID_PUBLIC_KEY=<web push public key>
#   VAPID_PRIVATE_KEY=<web push private key>
#   VAPID_SUBJECT=mailto:admin@qadiyonis.raafat.site
#
# Do NOT set PORT or DATABASE_URL in Coolify — compose handles those.
# Point domain https://qadiyonis.raafat.site:3000 at the app service.
